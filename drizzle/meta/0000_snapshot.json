        },
        "name": {
          "name": "name",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "expiry_date": {
          "name": "expiry_date",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": false
        },
        "id": {
          "name": "id",
          "type": "varchar(12)",
          "primaryKey": true,
          "notNull": true
        }
      },
      "definition": "select \"employee\".\"email\", \"employee\".\"given_name\", \"employee\".\"surname\", \"training\".\"name\", \"certificate\".\"expiry_date\", \"certificate\".\"id\" from \"certificate\" inner join \"employee\" on \"certificate\".\"issued_to\" = \"employee\".\"id\" inner join \"training_history\" on \"training_history\".\"certificate_id\" = \"certificate\".\"id\" inner join \"training\" on \"training_history\".\"training_code\" = \"training\".\"code\" where (\"certificate\".\"expiry_date\" <= CURRENT_DATE + INTERVAL '90 days' and \"certificate\".\"expiry_date\" >= CURRENT_DATE)",
      "name": "upcoming_renewals",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
  },
