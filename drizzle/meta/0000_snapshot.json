    "public.upcoming_renewals": {
      "columns": {
        "email": {
          "name": "email",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "given_name": {
          "name": "given_name",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "surname": {
          "name": "surname",
